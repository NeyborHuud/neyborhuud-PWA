{
  "name": "pwa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node start-dev.js",
    "dev:webpack": "node start-dev.js --webpack",
    "dev:fresh": "node scripts/kill-dev.cjs && node start-dev.js --clean",
    "dev:webpack:fresh": "node scripts/kill-dev.cjs && node start-dev.js --webpack --clean",
    "kill:all": "node scripts/kill-dev.cjs",
    "dev:clean": "node scripts/dev-clean.mjs",
    "dev:stable": "next dev",
    "dev:port": "node start-dev.js",
    "dev:3000": "set NEXT_DIST_DIR=.next-3000&& set PORT=3000&& next dev --turbopack --port 3000",
    "dev:3001": "set NEXT_DIST_DIR=.next-3001&& set PORT=3001&& next dev --turbopack --port 3001",
    "dev:3002": "set NEXT_DIST_DIR=.next-3002&& set PORT=3002&& next dev --turbopack --port 3002",
    "dev:3003": "set NEXT_DIST_DIR=.next-3003&& set PORT=3003&& next dev --turbopack --port 3003",
    "build": "next build --webpack",
    "build:cap": "node scripts/cap-build.mjs",
    "start": "next start",
    "lint": "node run-lint.mjs",
    "lint:strict": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:icons": "node scripts/generate-app-icons.mjs",
    "check:curl": "node scripts/curl-check.mjs",
    "check:auth": "node scripts/qa-auth-funnel.mjs",
    "check:auth:live": "node scripts/qa-auth-live.mjs",
    "check:all": "npm run typecheck && npm run lint && npm run build && npm run test"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@react-google-maps/api": "^2.20.8",
    "@react-oauth/google": "^0.13.5",
    "@tanstack/react-query": "^5.90.20",
    "@types/leaflet": "^1.9.21",
    "axios": "^1.13.3",
    "better-auth": "^1.6.21",
    "canvas-confetti": "^1.9.4",
    "framer-motion": "^12.39.0",
    "leaflet": "^1.9.4",
    "lottie-react": "^2.4.1",
    "lucide-react": "^1.7.0",
    "maplibre-gl": "^5.24.0",
    "next": "16.1.1",
    "next-pwa": "^5.6.0",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-intersection-observer": "^10.0.2",
    "react-leaflet": "^5.0.0",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query-devtools": "^5.91.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/next-pwa": "^5.6.9",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-loader": "^10.1.1",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "sharp": "0.33.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7",
    "ws": "^8.21.0"
  }
}
