# Copy to `.env.local` for local development.

# API base must include `/api/v1` — matches NeyborHuud-ServerSide mount.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1

# Socket.IO origin (no `/api/v1` path).
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# On the backend, set RESET_PASSWORD_REDIRECT_URL to this app’s reset page, e.g.:
#   http://localhost:3000/reset-password
# or production:
#   https://neyborhuud-pwa.vercel.app/reset-password
