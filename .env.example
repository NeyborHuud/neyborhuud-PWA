# Copy to `.env.local` for local development.

# API base must include `/api/v1` — must be the API host (api.neyborhuud.com), not the landing page domain.
# Local backend:
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api/v1

# Production (set these on the host for app.neyborhuud.com — do not point at neyborhuud.com):
# NEXT_PUBLIC_API_URL=https://api.neyborhuud.com/api/v1
# NEXT_PUBLIC_API_BASE_URL=https://api.neyborhuud.com/api/v1

# Socket.IO origin (no `/api/v1` path) — same host as the API.
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# Production:
# NEXT_PUBLIC_SOCKET_URL=https://api.neyborhuud.com

# On the backend `.env`, set:
#   BETTER_AUTH_URL=https://api.neyborhuud.com
#   FRONTEND_URL=https://app.neyborhuud.com
#   RESET_PASSWORD_REDIRECT_URL=https://app.neyborhuud.com/reset-password
