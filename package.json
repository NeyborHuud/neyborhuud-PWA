{
  "name": "next-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:port": "node start-dev.js",
    "dev:3000": "set NEXT_DIST_DIR=.next-3000&& set PORT=3000&& next dev --turbopack --port 3000",
    "dev:3001": "set NEXT_DIST_DIR=.next-3001&& set PORT=3001&& next dev --turbopack --port 3001",
    "dev:3002": "set NEXT_DIST_DIR=.next-3002&& set PORT=3002&& next dev --turbopack --port 3002",
    "dev:3003": "set NEXT_DIST_DIR=.next-3003&& set PORT=3003&& next dev --turbopack --port 3003",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "node run-lint.mjs",
    "lint:strict": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "echo \"No tests configured\" && exit 0",
    "check:curl": "curl --version",
    "check:all": "npm run typecheck && npm run lint && npm run build && npm run test"
  },
  "dependencies": {
    "@react-google-maps/api": "^2.20.8",
    "@tanstack/react-query": "^5.90.20",
    "@types/bootstrap": "^5.2.10",
    "@types/leaflet": "^1.9.21",
    "axios": "^1.13.3",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "leaflet": "^1.9.4",
    "lottie-react": "^2.4.1",
    "lucide-react": "^1.7.0",
    "next": "16.1.1",
    "next-pwa": "^5.6.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-intersection-observer": "^10.0.2",
    "react-leaflet": "^5.0.0",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query-devtools": "^5.91.2",
    "@types/next-pwa": "^5.6.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
